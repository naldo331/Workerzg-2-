rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---- GLOBAL FUNCTIONS ----
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---- SCHEMA HELPERS ----
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'role', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.role in ['customer', 'worker', 'admin']
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidWorkerProfile(data) {
      return data.keys().hasAll(['userId', 'category', 'rating', 'completedJobs', 'rank', 'approvalStatus'])
        && data.userId is string && data.userId.size() <= 128
        && data.category is string && data.category.size() <= 64
        && data.rating is number
        && data.completedJobs is number
        && data.rank in ['Bronze', 'Silver', 'Gold', 'Platinum', 'Elite']
        && data.approvalStatus in ['pending', 'approved', 'rejected'];
    }

    function isValidJob(data) {
      return data.keys().hasAll(['customerId', 'title', 'description', 'category', 'location', 'budget', 'status', 'paymentStatus', 'createdAt', 'updatedAt'])
        && data.customerId is string && data.customerId.size() <= 128
        && data.title is string && data.title.size() <= 128
        && data.description is string && data.description.size() <= 2048
        && data.category is string && data.category.size() <= 64
        && data.location is string && data.location.size() <= 256
        && data.budget is number
        && data.status in ['open', 'assigned', 'completed', 'cancelled']
        && data.paymentStatus in ['pending', 'paid']
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['jobId', 'amount', 'fee', 'status', 'createdAt'])
        && data.jobId is string && data.jobId.size() <= 128
        && data.amount is number
        && data.fee is number
        && data.status in ['pending', 'completed', 'failed']
        && data.createdAt is number;
    }

    // ---- RULES ----
    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    match /users/{userId} {
      allow read: if true; // Public profiles (needed for homepage)
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidUser(incoming())
        && incoming().userId == request.auth.uid
        && incoming().role != 'admin'; // Cannot self-assign admin
      
      allow update: if isSignedIn() 
        && (
          (request.auth.uid == userId && incoming().userId == existing().userId && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']))
          || 
          isAdmin()
        );
        
      allow delete: if isAdmin();
    }

    match /workers/{workerId} {
      allow read: if true; // Public marketplace
      
      allow create: if isSignedIn() 
        && request.auth.uid == workerId
        && isValidWorkerProfile(incoming())
        && incoming().userId == request.auth.uid
        && incoming().approvalStatus == 'pending'
        && incoming().rank == 'Bronze'
        && incoming().rating == 0
        && incoming().completedJobs == 0;
        
      allow update: if (isSignedIn() && request.auth.uid == workerId && incoming().userId == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['category', 'skills', 'description', 'startingPrice', 'location', 'phoneNumber', 'hasWhatsApp', 'updatedAt']))
        || isAdmin(); // Admin can update anything, worker can update their profile stuff
        
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true;
      
      allow create: if isSignedIn() 
        && isValidJob(incoming())
        && incoming().customerId == request.auth.uid
        && incoming().status == 'open'
        && incoming().paymentStatus == 'pending';
        
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == existing().customerId && existing().status == 'open' && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'location', 'budget', 'status', 'updatedAt', 'paymentStatus'])) ||
        (request.auth.uid == existing().customerId && existing().status != 'open' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'paymentStatus'])) ||
        (existing().status == 'open' && incoming().status == 'assigned' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'workerId', 'updatedAt']) && incoming().workerId == request.auth.uid) ||
        (request.auth.uid == existing().workerId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
