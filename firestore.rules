rules_version = '2';

/**
 * WORKERS GUILD SECURITY RULES
 *
 * CORE PHILOSOPHY:
 * This ruleset implements an "Authorization Independence" model. By denormalizing critical 
 * authorization data (like owner IDs and member maps) directly onto documents, we ensure 
 * that security checks are performant, scalable, and rarely require expensive cross-document lookups.
 *
 * DATA STRUCTURE:
 * - /worker_profiles: Publicly browsable (if approved), privately manageable by the worker.
 * - /job_requests: Shared access between the customer (creator), the assigned worker, and Sub-Guild members.
 * - /sub_guilds: Collective entities managed via a member/role map.
 * - /transactions: Private financial records restricted to the parties involved in a job.
 * - /skills & /job_categories: Publicly readable configuration data.
 * - /roles_admin: Global administrative privileges managed via a dedicated role collection.
 *
 * KEY SECURITY DECISIONS:
 * 1. Prototyping Flexibility: We enforce "Who" can access data, but not "What" the data looks like, 
 *    allowing for rapid field iteration without rule updates.
 * 2. Denormalization: Access to complex entities (JobRequests, Transactions) is granted by checking 
 *    UIDs stored directly in those documents (e.g., customerId, workerId, member maps).
 * 3. Implicit Ownership: For paths like /worker_profiles/{workerId}, ownership is verified by 
 *    matching the path variable directly against the user's Auth UID.
 * 4. Visibility Toggling: Worker profiles are only public if their status is set to 'APPROVED'.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner of an existing document. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has a global admin role. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the user is a member or leader in a denormalized map. */
    function isMapMember(memberMap) {
      return isSignedIn() && memberMap[request.auth.uid] != null;
    }

    /** @description Checks if the user is a leader in a role map. */
    function isLeader(memberMap) {
      return isSignedIn() && memberMap[request.auth.uid] == 'leader';
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for worker profiles. Owners manage their own, others can view if approved.
     * @path /worker_profiles/{workerId}
     * @allow User 'A' (get) their own profile.
     * @deny User 'B' (update) User 'A's profile.
     * @principle Implicit ownership via path-to-UID matching.
     */
    match /worker_profiles/{workerId} {
      allow get: if isOwner(workerId) || resource.data.status == 'APPROVED' || isAdmin();
      allow list: if true;
      allow create: if isOwner(workerId) && request.resource.data.id == workerId;
      allow update: if isExistingOwner(workerId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(workerId) || isAdmin();
    }

    /**
     * @description Rules for job requests. Access shared between customer, worker, and sub-guilds.
     * @path /job_requests/{jobRequestId}
     * @allow The customer (update) the job description.
     * @deny A random worker (get) a private, assigned job they aren't part of.
     * @principle Shared access via denormalized relationship fields.
     */
    match /job_requests/{jobRequestId} {
      function isInvolved() {
        return isOwner(resource.data.customerId) || isOwner(resource.data.assignedWorkerId) || isMapMember(resource.data.assignedSubGuildMembers) || isAdmin();
      }

      allow get: if resource.data.status == 'OPEN' || isInvolved();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isInvolved() && request.resource.data.customerId == resource.data.customerId;
      allow delete: if (resource != null && isOwner(resource.data.customerId)) || isAdmin();
    }

    /**
     * @description Rules for ratings. Customers write them, workers and admins read them.
     * @path /ratings/{ratingId}
     * @allow A worker (get) a rating left for them.
     * @deny A worker (update) a rating left by a customer.
     * @principle Protects the integrity of the feedback system by restricting writes to authors.
     */
    match /ratings/{ratingId} {
      allow get: if isSignedIn() && (isOwner(resource.data.customerId) || isOwner(resource.data.workerId) || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.customerId) && request.resource.data.customerId == resource.data.customerId;
      allow delete: if isExistingOwner(resource.data.customerId) || isAdmin();
    }

    /**
     * @description Rules for Sub-Guilds. Publicly visible, but only manageable by members.
     * @path /sub_guilds/{subGuildId}
     * @allow Any user (get) Sub-Guild info.
     * @deny A standard member (update) the Sub-Guild description; only leaders can.
     * @principle Shared access model using a role-based member map.
     */
    match /sub_guilds/{subGuildId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isLeader(resource.data.members) || isAdmin();
      allow delete: if isLeader(resource.data.members) || isAdmin();
    }

    /**
     * @description Rules for financial transactions. Strictly private to involved parties and admins.
     * @path /transactions/{transactionId}
     * @allow A customer (get) their payment history for a specific job.
     * @deny Any user (create) a transaction; usually restricted to system/admin.
     * @principle Maximum privacy for financial data.
     */
    match /transactions/{transactionId} {
      function canViewTransaction() {
        return isOwner(resource.data.customerId) || isOwner(resource.data.workerId) || isMapMember(resource.data.subGuildMembers) || isAdmin();
      }

      allow get: if canViewTransaction();
      allow list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Read-only public collections for app configuration.
     * @path /skills/{skillId}
     * @path /job_categories/{categoryId}
     */
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /job_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Internal administration roles.
     * @path /roles_admin/{adminId}
     */
    match /roles_admin/{adminId} {
      allow get: if isOwner(adminId);
      allow list, create, update, delete: if false;
    }
  }
}